rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get the current user's data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return request.auth != null && getUserData().role == 'super_admin';
    }

    // Helper to verify tenant isolation
    function isSameOrg(resourceOrgId) {
      return request.auth != null && getUserData().organizationId == resourceOrgId;
    }

    match /organizations/{orgId} {
      allow read: if isSuperAdmin() || (request.auth != null && getUserData().organizationId == orgId);
      allow write: if isSuperAdmin(); // Only backend or Super Admins can write billing/quota data
    }

    match /users/{userId} {
      allow read: if isSuperAdmin() || isSameOrg(resource.data.organizationId);
      // A user can edit their own basic info. Org admins can edit anyone in their org.
      allow write: if isSuperAdmin() || 
                      (request.auth != null && request.auth.uid == userId) || 
                      (isSameOrg(resource.data.organizationId) && getUserData().role == 'org_admin') ||
                      // Allow initial creation (since the user doc might not exist yet)
                      (request.method == 'create' && request.auth != null);
      allow delete: if request.auth != null && (request.auth.uid == userId || isSuperAdmin() || (isSameOrg(resource.data.organizationId) && getUserData().role == 'org_admin'));
    }

    match /bugs/{bugId} {
      // Enforce organization isolation upon read
      allow read: if isSuperAdmin() || isSameOrg(resource.data.organizationId);
      // Enforce organization isolation upon write (prevent forging orgId)
      allow create: if isSameOrg(request.resource.data.organizationId);
      allow update: if isSameOrg(resource.data.organizationId) && isSameOrg(request.resource.data.organizationId);
      allow delete: if isSameOrg(resource.data.organizationId) && (getUserData().role in ['org_admin', 'qa']);
    }
    
    match /projects/{projectId} {
      allow read: if isSuperAdmin() || isSameOrg(resource.data.organizationId);
      allow create: if isSameOrg(request.resource.data.organizationId);
      allow update: if isSameOrg(resource.data.organizationId) && isSameOrg(request.resource.data.organizationId);
      allow delete: if isSuperAdmin() || (isSameOrg(resource.data.organizationId) && getUserData().role in ['org_admin', 'qa']);
    }

    match /notifications/{notifId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}