rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserData() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Helper function to get the current user's data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isUserActive() {
      return isSignedIn() && 
             (!hasUserData() || getUserData().isActive == true);
    }

    function isSuperAdmin() {
      return isSignedIn() && hasUserData() && isUserActive() && getUserData().role in ['super_admin', 'Superadmin'];
    }

    // Helper to verify tenant isolation
    function isSameOrg(resourceOrgId) {
      return isSignedIn() && hasUserData() && isUserActive() && getUserData().organizationId == resourceOrgId;
    }

    function isOrgAdmin() {
      return isSignedIn() && hasUserData() && isUserActive() && getUserData().role in ['org_admin', 'super_admin', 'Admin', 'Superadmin', 'Manager'];
    }

    match /organizations/{orgId} {
      allow read: if isSuperAdmin() || (hasUserData() && getUserData().organizationId == orgId);
      // Allow any signed-in user to create an organization (Cold Signup)
      allow create: if isSignedIn();
      // Org admins can update their own org; only super admins can delete
      allow update: if isSuperAdmin() || (hasUserData() && getUserData().organizationId == orgId && isOrgAdmin());
      allow delete: if isSuperAdmin();
    }

    match /users/{userId} {
      // Allow initial creation if authenticated, ensuring ID matches or creator is Admin in same org
      allow create: if isSignedIn() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (isOrgAdmin() && request.resource.data.organizationId == getUserData().organizationId)
      );
      
      // A user can read their own document, or if it matches their email (for invite lookups)
      // Super admin can read any. Same-org users can read team members.
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (resource != null && resource.data.email == request.auth.token.email) ||
        (resource != null && isSameOrg(resource.data.organizationId))
      );

      // A user can update their own document (excluding roles/tenant hopping), org admins can manage their org's users,
      // super admins can manage anyone.
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'organizationId', 'isActive', 'email'])) ||
        isSuperAdmin() ||
        (isOrgAdmin() && isSameOrg(resource.data.organizationId) && 
         !(request.resource.data.role in ['super_admin', 'Superadmin']))
      );

      allow delete: if isSignedIn() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        (isOrgAdmin() && isSameOrg(resource.data.organizationId))
      );
    }

    match /bugs/{bugId} {
      // Super admin sees all; others see only their org's bugs, or public portal visitors see bugs in public projects
      allow read: if isSuperAdmin() || 
                  isSameOrg(resource.data.organizationId) || 
                  (resource.data.projectId != null && get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.isPublic == true);
      // Only create bugs in your own org
      allow create: if isSignedIn() && isSameOrg(request.resource.data.organizationId);
      // Only update bugs in your own org (can't change org)
      allow update: if isSuperAdmin() || (
        isSameOrg(resource.data.organizationId) && 
        isSameOrg(request.resource.data.organizationId)
      );
      allow delete: if isSuperAdmin() || (
        isSameOrg(resource.data.organizationId) && 
        isOrgAdmin()
      );
    }
    
    match /projects/{projectId} {
      // Allow read if Superadmin, member of same org, or if project is explicitly public
      allow read: if isSuperAdmin() || isSameOrg(resource.data.organizationId) || resource.data.isPublic == true;
      allow create: if isSignedIn() && isSameOrg(request.resource.data.organizationId);
      allow update: if isSuperAdmin() || (
        isSameOrg(resource.data.organizationId) && 
        isSameOrg(request.resource.data.organizationId)
      );
      allow delete: if isSuperAdmin() || (
        isSameOrg(resource.data.organizationId) && 
        isOrgAdmin()
      );
    }

    match /notifications/{notifId} {
      // Users can read and create their own notifications
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isSuperAdmin()
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isSuperAdmin()
      );
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /invitations/{inviteId} {
      allow read: if isSignedIn() && (isSuperAdmin() || (hasUserData() && resource.data.organizationId == getUserData().organizationId));
      allow create: if isSignedIn() && isOrgAdmin() && request.resource.data.organizationId == getUserData().organizationId;
      allow update, delete: if isSignedIn() && (isSuperAdmin() || (isOrgAdmin() && isSameOrg(resource.data.organizationId)) || request.auth.uid == resource.data.invitedBy);
    }
  }
}